          <mxGeometry height="100" width="260" x="1074" y="1051" as="geometry" />
        </mxCell>
        <mxCell id="0KoH8QsdyskSXtqt2C2q-30" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1F4E78;fontSize=10;align=left;verticalAlign=top;dashed=1;" value="📌 端口清单与归属&#xa;&#xa;:8091  前端入口 (Nginx / Vite)&#xa;:7072  be-scope-boot (主服务)&#xa;:8081~:8099  be-agent-runner (实例)&#xa;:8080  be-ontology-runtime (刘龙腾)&#xa;:18080  业务系统 (不在治理范围)&#xa;&#xa;⚠ :8091/.101 不是直连，必须经 7072 中转" vertex="1">
          <mxGeometry height="180" width="260" x="1074" y="651" as="geometry" />
        </mxCell>
        <mxCell id="0KoH8QsdyskSXtqt2C2q-31" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE699;strokeColor=#D79B00;fontSize=10;align=left;verticalAlign=top;dashed=1;" value="🛡 L4 治理 Hook 横切&#xa;&#xa;GateDecision 三态：&#xa;• ALLOW（绿）→ 进入 L3&#xa;• REQUIRE_HITL（橙）→ 暂停+卡片&#xa;• BLOCKED（红）→ 终止&#xa;&#xa;所有决策落 Audit + HITL 表" vertex="1">
          <mxGeometry height="100" width="260" x="1074" y="1171" as="geometry" />
        </mxCell>
        <mxCell id="0KoH8QsdyskSXtqt2C2q-32" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#B45F06;fontSize=10;align=left;verticalAlign=top;dashed=1;" value="🚦 HITL 闭环&#xa;&#xa;L4 REQUIRE_HITL → 前端 SSE 卡片&#xa;→ 用户 Approve → POST /hitl/approve&#xa;→ 用原 contextId 恢复 L3&#xa;→ 续走 8081→8080→18080" vertex="1">
          <mxGeometry height="100" width="260" x="1074" y="1291" as="geometry" />
        </mxCell>
        <mxCell id="0KoH8QsdyskSXtqt2C2q-33" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1F4E78;fontSize=10;align=left;verticalAlign=top;dashed=1;" value="💾 18 张表持久化（在 :7072 MySQL）&#xa;&#xa;A 配置态 5 表&#xa;B 会话态 6 表&#xa;C 监控态 2 表&#xa;D Runtime 5 表 (M11-M15)" vertex="1">
