        <mxCell id="Y2ZLCykh5mMw0kFJndtC-30" parent="Y2ZLCykh5mMw0kFJndtC-29" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#0070F2;fillColor=#FFFFFF;arcSize=24;absoluteArcSize=1;imageWidth=64;imageHeight=64;strokeWidth=1.5;" value="" vertex="1">
