        <mxCell id="Lm6IXje1hHrD9C9VsMu2-25" parent="1" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#d6b656;fillColor=#fff2cc;arcSize=24;absoluteArcSize=1;imageWidth=64;imageHeight=64;strokeWidth=1.5;dashed=1;dashPattern=8 8;opacity=70;" value="组件7&lt;div&gt;前端组件配置平台&lt;/div&gt;" vertex="1">
