        </mxCell>
        <mxCell id="Lm6IXje1hHrD9C9VsMu2-26" connectable="0" parent="1" style="group;align=left;" value="" vertex="1">
          <mxGeometry height="333" width="330" x="1020" y="841" as="geometry" />
        </mxCell>
        <mxCell id="Lm6IXje1hHrD9C9VsMu2-27" parent="Lm6IXje1hHrD9C9VsMu2-26" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#0070F2;fillColor=#EBF8FF;arcSize=24;absoluteArcSize=1;imageWidth=64;imageHeight=64;strokeWidth=1.5;" value="" vertex="1">
          <mxGeometry height="317.14285714285717" width="314.2857142857143" x="15.714285714285714" y="15.857142857142858" as="geometry" />
        </mxCell>
        <mxCell id="Lm6IXje1hHrD9C9VsMu2-28" parent="Lm6IXje1hHrD9C9VsMu2-26" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#0070F2;fillColor=#EBF8FF;arcSize=24;absoluteArcSize=1;imageWidth=64;imageHeight=64;strokeWidth=1.5;align=left;" value="&lt;div&gt;PoC 最小实现建议（可选/必选标注）&lt;/div&gt;&lt;div&gt;必选（保证“能跑通业务闭环”）&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;本体建模（实体/字段/关系）+ 版本&lt;/div&gt;&lt;div&gt;CQRS 引擎（含分页/过滤）&lt;/div&gt;&lt;div&gt;UI Schema 自动生成 + 渲染（列表/详情/编辑）&lt;/div&gt;&lt;div&gt;RBAC 最小版（页面/动作/字段可见 + 行级过滤一种）&lt;/div&gt;&lt;div&gt;Ontology→RDB 映射（至少支持 1-N）&lt;/div&gt;&lt;div&gt;发布包（导出/导入）+ 一个测试环境部署&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;可选（预留接口，做案例测试）&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;推理/复杂语义查询&lt;/span&gt;&lt;/div&gt;&lt;div&gt;工作流引擎/事件总线&lt;/div&gt;&lt;div&gt;多数据源与连接器市场&lt;/div&gt;&lt;div&gt;强可观测与灰度发布&lt;/div&gt;" vertex="1">
          <mxGeometry height="317.14285714285717" width="314.2857142857143" as="geometry" />
        </mxCell>
        <mxCell id="Lm6IXje1hHrD9C9VsMu2-29" parent="1" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#07838F;fillColor=#DAFDF5;arcSize=24;absoluteArcSize=1;imageWidth=64;imageHeight=64;strokeWidth=1.5;verticalAlign=top;align=left;fontSize=16;fontStyle=1;spacingTop=10;spacingLeft=20;" value="&lt;div&gt;L0. 建模与治理层（Design-time）&lt;/div&gt;&lt;div&gt;本体建模工作台（Ontology Modeling Studio）&lt;/div&gt;&lt;div&gt;类/属性/关系/约束（含 SHACL/规则）&lt;/div&gt;&lt;div&gt;版本、变更记录、review/approval（PoC 可简化）&lt;/div&gt;&lt;div&gt;页面建模工作台（UI Schema Studio）&lt;/div&gt;&lt;div&gt;列表/详情/编辑表单的 UI Schema（由本体自动生成 + 可手工调整）&lt;/div&gt;&lt;div&gt;动作/流程建模（Actions/Workflow Studio）&lt;/div&gt;&lt;div&gt;Action 定义（服务接口、参数、返回）&lt;/div&gt;&lt;div&gt;状态机/审批（PoC 可选）&lt;/div&gt;&lt;div&gt;权限策略建模（Policy Studio）&lt;/div&gt;&lt;div&gt;RBAC（角色-对象-字段-动作）&lt;/div&gt;&lt;div&gt;数据范围（按组织/部门/拥有者过滤）&lt;/div&gt;&lt;div&gt;产物（发布包的核心）：Ontology Schema + UI Schema + Action Schema + Policy Schema + Migrations&lt;/div&gt;" vertex="1">
          <mxGeometry height="310" width="510" x="630" y="1200" as="geometry" />
        </mxCell>
        <mxCell id="Lm6IXje1hHrD9C9VsMu2-30" parent="1" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#07838F;fillColor=#DAFDF5;arcSize=24;absoluteArcSize=1;imageWidth=64;imageHeight=64;strokeWidth=1.5;verticalAlign=top;align=left;fontSize=16;fontStyle=1;spacingTop=10;spacingLeft=20;" value="&lt;div&gt;L1. 元数据与编译层（Metadata &amp;amp; Compilation）&lt;/div&gt;&lt;div&gt;模型注册表 / 元数据仓库（Metadata Registry）&lt;/div&gt;&lt;div&gt;存储上述 schema 的版本化快照（可 JSON/YAML）&lt;/div&gt;&lt;div&gt;生成器/编译器（Codegen / Compiler）&lt;/div&gt;&lt;div&gt;生成：CQRS API、校验器、SQL 映射、默认 UI 页面、权限过滤器&lt;/div&gt;&lt;div&gt;生成：数据库迁移脚本（DDL）或迁移计划（PoC 最少“建表+字段增量”）&lt;/div&gt;" vertex="1">
          <mxGeometry height="160" width="510" x="110" y="1200" as="geometry" />
        </mxCell>
        <mxCell id="Lm6IXje1hHrD9C9VsMu2-31" parent="1" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#07838F;fillColor=#DAFDF5;arcSize=24;absoluteArcSize=1;imageWidth=64;imageHeight=64;strokeWidth=1.5;verticalAlign=top;align=left;fontSize=16;fontStyle=1;spacingTop=10;spacingLeft=20;" value="&lt;div&gt;L2. 运行时核心层（Runtime Core）&lt;/div&gt;&lt;div&gt;运行时网关（Runtime API Gateway）&lt;/div&gt;&lt;div&gt;统一入口：鉴权、限流、traceId、错误码&lt;/div&gt;&lt;div&gt;本体服务（Ontology Service / Metadata API）&lt;/div&gt;&lt;div&gt;提供模型读取接口（entities/fields/relations/actions/ui schema）&lt;/div&gt;&lt;div&gt;提供语义查询接口（建议 PoC：查询 DSL → SQL）&lt;/div&gt;&lt;div&gt;业务运行时（App Runtime）&lt;/div&gt;&lt;div&gt;自动 CQRS 引擎：实体 CQRS、列表查询（分页/过滤/排序）&lt;/div&gt;&lt;div&gt;Action 执行引擎：执行模型定义的业务动作（事务边界）&lt;/div&gt;&lt;div&gt;事件总线（可选）：实体变更事件（用于流程、通知、集成）&lt;/div&gt;&lt;div&gt;权限与审计（AuthZ &amp;amp; Audit）&lt;/div&gt;&lt;div&gt;权限裁剪：对象/字段/动作/行级过滤&lt;/div&gt;&lt;div&gt;审计日志：谁在何时对哪个对象做了什么（CRUD/Action/模型变更）&lt;/div&gt;" vertex="1">
          <mxGeometry height="290" width="510" x="110" y="900" as="geometry" />
        </mxCell>
        <mxCell id="Lm6IXje1hHrD9C9VsMu2-32" parent="1" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#07838F;fillColor=#DAFDF5;arcSize=24;absoluteArcSize=1;imageWidth=64;imageHeight=64;strokeWidth=1.5;verticalAlign=top;align=left;fontSize=16;fontStyle=1;spacingTop=10;spacingLeft=20;" value="&lt;div&gt;L3. 数据与集成层（Data &amp;amp; Integration）&lt;/div&gt;&lt;div&gt;关系型数据库（RDB）&lt;/div&gt;&lt;div&gt;业务数据表（实体实例）&lt;/div&gt;&lt;div&gt;权限辅助表（可选：组织/角色映射）&lt;/div&gt;&lt;div&gt;映射层（Ontology→RDB Mapping Layer）&lt;/div&gt;&lt;div&gt;本体对象/关系 → 表结构与关联表策略&lt;/div&gt;&lt;div&gt;Query DSL → SQL（含权限过滤与租户过滤）&lt;/div&gt;&lt;div&gt;连接器/集成（Connectors）&lt;/div&gt;&lt;div&gt;HTTP/Webhook（PoC 建议至少做一个）&lt;/div&gt;&lt;div&gt;外部 DB/文件（先预留）&lt;/div&gt;" vertex="1">
          <mxGeometry height="230" width="510" x="-50" y="660" as="geometry" />
        </mxCell>
        <mxCell id="Lm6IXje1hHrD9C9VsMu2-33" parent="1" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#07838F;fillColor=#DAFDF5;arcSize=24;absoluteArcSize=1;imageWidth=64;imageHeight=64;strokeWidth=1.5;verticalAlign=top;align=left;fontSize=16;fontStyle=1;spacingTop=10;spacingLeft=20;" value="&lt;div&gt;L5. 发布与运维层（Release &amp;amp; Ops）&lt;/div&gt;&lt;div&gt;发布包（Application Bundle）&lt;/div&gt;&lt;div&gt;schema + migrations + 前端资源 + 配置&lt;/div&gt;&lt;div&gt;部署与版本管理（Deploy/Versioning）&lt;/div&gt;&lt;div&gt;环境（dev/test/prod）+ 回滚&lt;/div&gt;&lt;div&gt;可观测性（Observability）&lt;/div&gt;&lt;div&gt;日志/指标/链路追踪（前端→网关→运行时→DB）&lt;/div&gt;" vertex="1">
          <mxGeometry height="170" width="510" x="640" y="110" as="geometry" />
        </mxCell>
